// ──────────────────────────────────────────
// NAVIGATION
// ──────────────────────────────────────────

function showCity(id) {
  const city = cities[id];
  if (!city) return;

  document.getElementById("city-hero-img").src = city.img;
  document.getElementById("city-hero-img").alt = city.name;
  document.getElementById("city-title").textContent = city.name;
  document.getElementById("city-desc").textContent  = city.desc;

  const list = document.getElementById("landmarks-list");
  list.innerHTML = city.landmarks.map(buildLandmarkCard).join("");

  const home       = document.getElementById("home");
  const cityScreen = document.getElementById("city-screen");

  home.classList.remove("active");
  cityScreen.classList.add("active", "animate-in");
  cityScreen.addEventListener("animationend", () => {
    cityScreen.classList.remove("animate-in");
  }, { once: true });

  document.getElementById("city-body").scrollTop = 0;
}

function goHome() {
  const home       = document.getElementById("home");
  const cityScreen = document.getElementById("city-screen");

  cityScreen.classList.remove("active");
  home.classList.add("active", "animate-back");
  home.addEventListener("animationend", () => {
    home.classList.remove("animate-back");
  }, { once: true });
}

